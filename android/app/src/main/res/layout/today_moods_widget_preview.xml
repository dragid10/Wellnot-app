<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="@dimen/widget_padding"
    android:background="@color/widget_background">

    <!-- Header row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/widget_today_moods_label"
            android:textColor="@color/widget_teal_primary"
            android:textSize="@dimen/widget_header_font_size"
            android:textStyle="bold" />

        <FrameLayout
            android:layout_width="@dimen/widget_add_button_size"
            android:layout_height="@dimen/widget_add_button_size"
            android:background="@drawable/widget_add_button_bg">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="+"
                android:textColor="@android:color/white"
                android:textSize="@dimen/widget_add_button_font_size"
                android:textStyle="bold" />
        </FrameLayout>
    </LinearLayout>

    <!-- Entry 1 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="@dimen/widget_header_bottom_spacing"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="9:30 AM"
            android:textSize="@dimen/widget_time_font_size"
            android:textColor="@color/widget_text_primary"
            android:layout_marginEnd="@dimen/widget_entry_horizontal_spacing" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="😊 - Headache, Fatigue"
            android:textSize="@dimen/widget_content_font_size"
            android:textColor="@color/widget_text_primary"
            android:singleLine="true"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- Entry 2 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="@dimen/widget_entry_vertical_spacing"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2:15 PM"
            android:textSize="@dimen/widget_time_font_size"
            android:textColor="@color/widget_text_primary"
            android:layout_marginEnd="@dimen/widget_entry_horizontal_spacing" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="😐 - Nausea"
            android:textSize="@dimen/widget_content_font_size"
            android:textColor="@color/widget_text_primary"
            android:singleLine="true"
            android:ellipsize="end" />
    </LinearLayout>
</LinearLayout>
