<?xml version="1.0" encoding="utf-8"?>
<!-- Backup rules for Android 11 and below (fullBackupContent).
     Excludes the SQLite database and SharedPreferences from Google Drive
     auto-backup to prevent user data from syncing to the cloud. -->
<full-backup-content>
    <exclude domain="database" path="." />
    <exclude domain="file" path="app_flutter/db.sqlite" />
    <exclude domain="file" path="app_flutter/db.sqlite-journal" />
    <exclude domain="file" path="app_flutter/db.sqlite-wal" />
</full-backup-content>
